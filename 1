def gen_ttt_markup(board, msg_id):
    markup = types.InlineKeyboardMarkup(row_width=4)
    btns = []
    for i, item in enumerate(board):
        display = item if item != ' ' else '🔹'
        btns.append(types.InlineKeyboardButton(display, callback_data=f"click_ttt_{msg_id}_{i}"))
    markup.add(*btns)
    return markup

