def process_promo_redeem(message):
    code = message.text.strip()
    user_id = message.from_user.id
    
    conn = get_db_connection()
    cursor = conn.cursor()
    cursor.execute('SELECT * FROM promos WHERE code = ?', (code,))
    promo = cursor.fetchone()
    
    if not promo:
        bot.send_message(message.chat.id, "❌ Такого промокода не существует.")
        conn.close()
        return
        
    cursor.execute('SELECT * FROM promo_history WHERE code = ? AND user_id = ?', (code, user_id))
    history = cursor.fetchone()
    
    if history:
        bot.send_message(message.chat.id, "❌ Ты уже активировал этот промокод!")
        conn.close()
        return
        
    if promo['current_uses'] >= promo['max_uses']:
        bot.send_message(message.chat.id, "❌ Лимит активаций этого промокода исчерпан.")
        conn.close()
        return
        
    cursor.execute('UPDATE promos SET current_uses = current_uses + 1 WHERE code = ?', (code,))
    cursor.execute('INSERT INTO promo_history (code, user_id) VALUES (?, ?)', (code, user_id))
    conn.commit()
    conn.close()
    
    update_balance(user_id, promo['reward'])
    bot.send_message(message.chat.id, f"🎟 Успешно! Промокод активирован. Тебе начислено <b>{promo['reward']:,} Ноксов</b>!", parse_mode='HTML')

