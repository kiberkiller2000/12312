        cursor.execute('INSERT OR REPLACE INTO promos (code, max_uses, reward) VALUES (?, ?, ?)', (code, max_uses, reward))
        conn.commit()
        conn.close()
        
        bot.send_message(message.chat.id, f"✅ Промокод <code>{code}</code> успешно создан!\nАктиваций: {max_uses}\nНаграда: {reward:,} ноксов.", parse_mode='HTML')
