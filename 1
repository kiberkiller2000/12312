def run_dice_match(chat_id, p1, p2, stake):
    msg = bot.send_message(chat_id, f"🎲 Бросаем кубики за <b>{p1['first_name']}</b>...")
    d1 = bot.send_dice(chat_id).dice.value
    time.sleep(3)
    
    bot.send_message(chat_id, f"🎲 Бросаем кубики за <b>{p2['first_name']}</b>...")
    d2 = bot.send_dice(chat_id).dice.value
    time.sleep(3)
    
    if d1 > d2:
        update_balance(p1['user_id'], stake)
        update_balance(p2['user_id'], -stake)
        update_streak(p1['user_id'], is_win=True, stake=stake)
        update_streak(p2['user_id'], is_win=False, stake=stake)
        bot.send_message(chat_id, f"👑 <b>{p1['first_name']}</b> выбивает {d1} против {d2} и забирает <b>{stake:,} ноксов</b>!", parse_mode='HTML')
    elif d2 > d1:
        update_balance(p2['user_id'], stake)
        update_balance(p1['user_id'], -stake)
        update_streak(p2['user_id'], is_win=True, stake=stake)
        update_streak(p1['user_id'], is_win=False, stake=stake)
        bot.send_message(chat_id, f"👑 <b>{p2['first_name']}</b> выбивает {d2} против {d1} и забирает <b>{stake:,} ноксов</b>!", parse_mode='HTML')
    else:
        bot.send_message(chat_id, f"🤝 Ничья ({d1}:{d2})! Перекидываем кости, бабки остаются на кону...")
        run_dice_match(chat_id, p1, p2, stake)


