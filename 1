# Перевод средств
@bot.message_handler(func=lambda m: m.text and m.text.strip().lower().startswith('нк перевод'))
def cmd_transfer(message):
    match = re.match(r'^нк перевод\s+(\d+)$', message.text.strip().lower())
    if not match:
        return
        
    if not message.reply_to_message:
        bot.reply_to(message, "❌ Эта команда должна быть ответом (реплаем) на сообщение того, кому переводишь!")
        return
        
    amount = int(match.group(1))
    if amount <= 0:
        bot.reply_to(message, "❌ Серьезно? Давай нормальную сумму.")
        return
        
    from_user = get_or_create_user(message.from_user.id, message.from_user.username, message.from_user.first_name)
    to_user = get_or_create_user(message.reply_to_message.from_user.id, message.reply_to_message.from_user.username, message.reply_to_message.from_user.first_name)
    
    if from_user['user_id'] == to_user['user_id']:
        bot.reply_to(message, "❌ Переводить самому себе — это шизофрения.")
        return
        
    if from_user['balance'] < amount:
        bot.reply_to(message, "❌ У тебя нет столько Ноксов на кармане.")
        return
        
    update_balance(from_user['user_id'], -amount)
    update_balance(to_user['user_id'], amount)
    
    bot.send_message(message.chat.id, f"💸 Игрок <b>{from_user['first_name']}</b> перевёл <b>{amount:,} Ноксов</b> игроку <b>{to_user['first_name']}</b>!", parse_mode='HTML')


