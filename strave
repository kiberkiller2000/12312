BypassGap() {
    Sleep(Random(1, 2))
}

Null_HandleHorizontal() {
    global null_keys, null_lastPressed, g_NullBypassEnabled
    if (null_keys["a"] && null_keys["d"]) {
        if (null_lastPressed["horizontal"] == "a") {
            Send("{Blind}{d up}")
            if g_NullBypassEnabled
                BypassGap()
            Send("{Blind}{a down}")
        } else {
            Send("{Blind}{a up}")
            if g_NullBypassEnabled
                BypassGap()
            Send("{Blind}{d down}")
        }
    } else if (null_keys["a"]) {
        Send("{Blind}{d up}")
        if g_NullBypassEnabled
            BypassGap()
        Send("{Blind}{a down}")
    } else if (null_keys["d"]) {
        Send("{Blind}{a up}")
        if g_NullBypassEnabled
            BypassGap()
        Send("{Blind}{d down}")
    } else {
        Send("{Blind}{a up}{d up}")
    }
}

Null_HandleVertical() {
    global null_keys, g_NullBypassEnabled
    if (null_keys["w"] && null_keys["s"]) {
        Send("{Blind}{w up}{s up}")
    } else if (null_keys["w"]) {
        Send("{Blind}{s up}")
        if g_NullBypassEnabled
            BypassGap()
        Send("{Blind}{w down}")
    } else if (null_keys["s"]) {
        Send("{Blind}{w up}")
        if g_NullBypassEnabled
            BypassGap()
        Send("{Blind}{s down}")
    } else {
        Send("{Blind}{w up}{s up}")
    }
}

Null_Press(key, dir) {
    global g_NullEnabled, null_keys, null_lastPressed
    if !g_NullEnabled {
        Send("{Blind}{" key " down}")
        return
    }
    null_keys[key] := 1
    null_lastPressed[dir] := key
    if (dir = "horizontal") {
        Null_HandleHorizontal()
    } else {
        Null_HandleVertical()
    }
}

Null_Release(key, dir) {
    global g_NullEnabled, null_keys
    if !g_NullEnabled {
        Send("{Blind}{" key " up}")
        null_keys[key] := 0
        return
    }
    null_keys[key] := 0
    if (dir = "horizontal") {
        Null_HandleHorizontal()
    } else {
        Null_HandleVertical()
    }
}

mouseXY(x, y) {
    DllCall("mouse_event", "UInt", 0x01, "Int", x, "Int", y, "UInt", 0, "Ptr", 0)
}

DoJumpAndReleaseW() {
    if GetKeyState("w", "P")
        Send("{w up}")
    Send("{space}")
}

strafe(left) {
    global g_moveX, g_moveY, g_moveCount, g_sleepInterval, g_Paused, g_StrafeBypassEnabled
    if g_Paused
        return
    key := left ? "d" : "a"
    hMove := left ? g_moveX : -g_moveX
    vMove := left ? -g_moveY : g_moveY
    
    DllCall("winmm\timeBeginPeriod", "UInt", 1)
    
    if g_StrafeBypassEnabled {
        if (left) {
            Send("{a up}")
            BypassGap()
            Send("{d down}")
        } else {
            Send("{d up}")
            BypassGap()
            Send("{a down}")
        }
    } else {
        Send("{" key " down}")
    }
    
    DllCall("Sleep", "UInt", 5)
    Loop g_moveCount {
        if g_Paused
            break
        mouseXY(hMove, vMove)
        DllCall("Sleep", "UInt", g_sleepInterval)
    }
    
    if !g_StrafeBypassEnabled {
        Send("{" key " up}")
    } else {
        Send("{" (left ? "d" : "a") " up}")
    }
    
    DllCall("winmm\timeEndPeriod", "UInt", 1)
}

StartBhopSpam() {
    global g_BhopEnabled, g_BhopMinDelay, g_BhopMaxDelay, g_BhopSpamming, g_Paused
    while g_BhopSpamming {
        if !g_BhopEnabled or g_Paused {
            g_BhopSpamming := false
            break
        }
        Send("{Space}")
        Sleep(Random(g_BhopMinDelay, g_BhopMaxDelay))
    }
}

DoCrouch66() {
    if GetKeyState("w", "P")
        Send("{w up}")
    Send("{Ctrl down}")
    Sleep(22)
    Send("{Space}")
    KeyWait("XButton1")
    Send("{Ctrl up}")
}

DoCrouch65() {
    if GetKeyState("w", "P")
        Send("{w up}")
    Send("{Space}")
    Sleep(5)
    Send("{Ctrl down}")
    KeyWait("XButton2")
    Send("{Ctrl up}")
}

LoadSettings() {
    global g_moveX, g_moveY, g_moveCount, g_sleepInterval, g_BhopEnabled, g_BhopMinDelay, g_BhopMaxDelay, g_CrouchEnabled, g_NullEnabled, g_NullBypassEnabled, g_StrafeBypassEnabled
    if !FileExist("settings.ini")
        return
    g_moveX := IniRead("settings.ini", "LongJump", "moveX", g_moveX)
    g_moveY := IniRead("settings.ini", "LongJump", "moveY", g_moveY)
    g_moveCount := IniRead("settings.ini", "LongJump", "moveCount", g_moveCount)
    g_sleepInterval := IniRead("settings.ini", "LongJump", "sleepInterval", g_sleepInterval)
    g_BhopEnabled := IniRead("settings.ini", "Bhop", "enabled", g_BhopEnabled)
    g_BhopMinDelay := IniRead("settings.ini", "Bhop", "minDelay", g_BhopMinDelay)
    g_BhopMaxDelay := IniRead("settings.ini", "Bhop", "maxDelay", g_BhopMaxDelay)
    g_CrouchEnabled := IniRead("settings.ini", "Crouch", "enabled", g_CrouchEnabled)
    g_NullEnabled := IniRead("settings.ini", "Null", "enabled", g_NullEnabled)
    g_NullBypassEnabled := IniRead("settings.ini", "NullBypass", "enabled", g_NullBypassEnabled)
    g_StrafeBypassEnabled := IniRead("settings.ini", "StrafeBypass", "enabled", g_StrafeBypassEnabled)
}

SaveSettings() {
    global g_moveX, g_moveY, g_moveCount, g_sleepInterval, g_BhopEnabled, g_BhopMinDelay, g_BhopMaxDelay, g_CrouchEnabled, g_NullEnabled, g_NullBypassEnabled, g_StrafeBypassEnabled
    IniWrite(g_moveX, "settings.ini", "LongJump", "moveX")
    IniWrite(g_moveY, "settings.ini", "LongJump", "moveY")
    IniWrite(g_moveCount, "settings.ini", "LongJump", "moveCount")
    IniWrite(g_sleepInterval, "settings.ini", "LongJump", "sleepInterval")
    IniWrite(g_BhopEnabled, "settings.ini", "Bhop", "enabled")
    IniWrite(g_BhopMinDelay, "settings.ini", "Bhop", "minDelay")
    IniWrite(g_BhopMaxDelay, "settings.ini", "Bhop", "maxDelay")
    IniWrite(g_CrouchEnabled, "settings.ini", "Crouch", "enabled")
    IniWrite(g_NullEnabled, "settings.ini", "Null", "enabled")
    IniWrite(g_NullBypassEnabled, "settings.ini", "NullBypass", "enabled")
    IniWrite(g_StrafeBypassEnabled, "settings.ini", "StrafeBypass", "enabled")
}

