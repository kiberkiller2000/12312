Null_Check(cbNull, cbNullBypass) {
    global g_NullEnabled, g_NullBypassEnabled
    g_NullEnabled := cbNull.Value
    if !g_NullEnabled {
        cbNullBypass.Value := false
        g_NullBypassEnabled := false
    }
}

NullBypass_Check(cbNullBypass, cbNull) {
    global g_NullBypassEnabled, g_NullEnabled
    g_NullBypassEnabled := cbNullBypass.Value
    if g_NullBypassEnabled && !g_NullEnabled {
        cbNull.Value := true
        g_NullEnabled := true
    }
}

StrafeBypass_Check(cbStrafeBypass) {
    global g_StrafeBypassEnabled
    g_StrafeBypassEnabled := cbStrafeBypass.Value
}

BHOP_Check(bhop, crouch) {
    global g_BhopEnabled, g_CrouchEnabled, g_BhopSpamming
    if bhop.Value {
        crouch.Value := false
        g_CrouchEnabled := false
        g_BhopEnabled := true
        g_BhopSpamming := false
    } else {
        g_BhopEnabled := false
        g_BhopSpamming := false
    }
}

Crouch_Check(crouch, bhop) {
    global g_CrouchEnabled, g_BhopEnabled, g_BhopSpamming
    if crouch.Value {
        bhop.Value := false
        g_BhopEnabled := false
        g_BhopSpamming := false
        g_CrouchEnabled := true
    } else {
        g_CrouchEnabled := false
    }
}

ApplySettings(edX, edY, edSteps, edSpeed, cbBhop, edBhopMin, edBhopMax, cbCrouch, cbNull, cbNullBypass, cbStrafeBypass, txtStatus) {
    global g_moveX, g_moveY, g_moveCount, g_sleepInterval
    global g_BhopEnabled, g_BhopMinDelay, g_BhopMaxDelay, g_BhopSpamming
    global g_CrouchEnabled, g_Paused, g_NullEnabled, g_NullBypassEnabled, g_StrafeBypassEnabled, MainGui
    
    g_moveX := Integer(edX.Value)
    g_moveY := Integer(edY.Value)
    g_moveCount := Integer(edSteps.Value)
    g_sleepInterval := Integer(edSpeed.Value)
    g_BhopEnabled := cbBhop.Value
    g_BhopMinDelay := Integer(edBhopMin.Value)
    g_BhopMaxDelay := Integer(edBhopMax.Value)
    g_CrouchEnabled := cbCrouch.Value
    g_NullEnabled := cbNull.Value
    g_NullBypassEnabled := cbNullBypass.Value
    g_StrafeBypassEnabled := cbStrafeBypass.Value
    
    if !g_BhopEnabled or g_CrouchEnabled {
        g_BhopSpamming := false
    }
    
    SaveSettings()
    
    if IsObject(MainGui) && WinExist("ahk_id " MainGui.Hwnd) {
        try {
            txtStatus.Value := "SAVED!"
            txtStatus.SetFont("cFFFF00")
            Sleep(1500)
            txtStatus.Value := g_Paused ? "PAUSED" : "ACTIVE"
            txtStatus.SetFont("c" (g_Paused ? "FF4444" : "44FF44"))
        }
    }
}

PauseFromMenu(txtStatus) {
    global g_Paused, g_BhopSpamming, MainGui
    g_Paused := !g_Paused
    if g_Paused
        g_BhopSpamming := false
    if IsObject(MainGui) && WinExist("ahk_id " MainGui.Hwnd) {
        txtStatus.Value := g_Paused ? "PAUSED" : "ACTIVE"
        txtStatus.SetFont("c" (g_Paused ? "FF4444" : "44FF44"))
    }
}

CloseMenu(*) {
    global MainGui
    if IsObject(MainGui) {
        MainGui.Destroy()
        MainGui := ""
    }
}

OnLButtonDown(wParam, lParam, msg, hwnd) {
    global MainGui, g_MoveWindow, g_MouseStartX, g_MouseStartY, g_WindowStartX, g_WindowStartY
    if !IsObject(MainGui) {
        return
    }
    MouseGetPos(&mouseX, &mouseY, &winUnderMouse)
    if winUnderMouse = MainGui.Hwnd {
        WinGetPos(&winX, &winY,,, winUnderMouse)
        relativY := mouseY - winY
        if relativY < 80 {
            g_MoveWindow := true
            g_MouseStartX := mouseX
            g_MouseStartY := mouseY
            g_WindowStartX := winX
            g_WindowStartY := winY
            return
        }
    }
}

OnLButtonUp(wParam, lParam, msg, hwnd) {
